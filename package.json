{
  "name": "luxora-workspace",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "install:all": "pnpm install --no-frozen-lockfile",
    "build:frontend": "pnpm --dir frontend run build",
    "typecheck:backend": "pnpm --dir backend run typecheck",
    "deploy:backend": "pnpm --dir backend exec wrangler deploy"
  }
}
